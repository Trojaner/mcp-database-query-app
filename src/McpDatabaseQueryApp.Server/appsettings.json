{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "McpDatabaseQueryApp": {
    "MetadataDbPath": "%APPDATA%/McpDatabaseQueryApp/mcp-database-query-app.db",
    "DefaultResultLimit": 500,
    "MaxResultLimit": 5000,
    "AllowDisableLimit": true,
    "ReadOnlyByDefault": true,
    "SlowQueryThresholdMs": 2000,
    "ConnectionIdleTimeout": "00:30:00",
    "AutoConnect": true,
    "Transport": {
      "Stdio": { "Enabled": true },
      "Http":  { "Enabled": true, "Urls": "http://127.0.0.1:5218" }
    },
    "Ui": { "Enabled": true },
    "Logging": {
      "EmitSqlToMcpClient": true,
      "RedactLiteralsInLogs": true
    },
    "Secrets": {
      "KeyRef": "UserSecrets:McpDatabaseQueryApp:MasterKey"
    },
    "OAuth2": {
      "Authority": null,
      "Audience": null,
      "RequireHttps": true,
      "MetadataAddress": null,
      "AutoProvisionProfiles": true
    },
    "Authorization": {
      "DefaultProfilePolicy": "AllowAll",
      "CacheTtl": "00:00:30",
      "StaticEntries": []
    },
    "DataIsolation": {
      "StaticRules": []
    }
  }
}
